import React, { useState, useEffect } from 'react';
import { ShoppingCart, Plus, Trash2, Upload, Check, X, ChevronRight, Store, Settings, Package, User, Edit2, Share2 } from 'lucide-react';
import { motion, AnimatePresence } from 'motion/react';

interface Product {
  id: number;
  name: string;
  price: number;
  image_url: string;
  description: string;
  customizable: number;
}

interface CartItem extends Product {
  quantity: number;
  size: string;
  custom_image_url?: string;
}

const DELIVERY_FEES: { [key: string]: number } = {
  'القاهرة': 50,
  'الجيزة': 50,
  'الإسكندرية': 60,
  'الدلتا': 70,
  'الصعيد': 80,
  'أخرى': 100
};

export default function App() {
  const [products, setProducts] = useState<Product[]>([]);
  const [cart, setCart] = useState<CartItem[]>([]);
  const [view, setView] = useState<'home' | 'cart' | 'admin' | 'product'>('home');
  const [selectedProduct, setSelectedProduct] = useState<Product | null>(null);
  const [selectedSize, setSelectedSize] = useState<string>('M');
  const [customImageUrl, setCustomImageUrl] = useState<string>('');
  const [isAddingToCart, setIsAddingToCart] = useState(false);
  const [adminForm, setAdminForm] = useState({ name: '', price: '', image_url: '', description: '', customizable: true });
  const [editingId, setEditingId] = useState<number | null>(null);
  const [checkoutForm, setCheckoutForm] = useState({ name: '', email: '', phone: '', location: 'القاهرة' });
  const [orderSuccess, setOrderSuccess] = useState(false);
  const [lastWhatsappUrl, setLastWhatsappUrl] = useState('');
  const [isUploading, setIsUploading] = useState(false);
  const [isAdminAuthenticated, setIsAdminAuthenticated] = useState(false);
  const [adminToken, setAdminToken] = useState('');
  const [adminPasswordInput, setAdminPasswordInput] = useState('');

  useEffect(() => {
    fetchProducts();
  }, []);

  const fetchProducts = async () => {
    try {
      const res = await fetch('/api/products');
      const data = await res.json();
      setProducts(data);
    } catch (err) {
      console.error('Failed to fetch products', err);
    }
  };

  const handleShareStore = () => {
    const message = "شاهد متجر FABRIX لأحدث الهوديز والتصاميم المخصصة!";
    const url = window.location.origin;
    const whatsappUrl = `https://wa.me/?text=${encodeURIComponent(message + " " + url)}`;
    window.open(whatsappUrl, '_blank');
  };

  const addToCart = (product: Product) => {
    const newItem: CartItem = {
      ...product,
      quantity: 1,
      size: selectedSize,
      custom_image_url: customImageUrl || undefined
    };
    setCart([...cart, newItem]);
    setIsAddingToCart(true);
    setTimeout(() => {
      setIsAddingToCart(false);
      setView('home');
      setSelectedProduct(null);
      setCustomImageUrl('');
    }, 1000);
  };

  const removeFromCart = (index: number) => {
    const newCart = [...cart];
    newCart.splice(index, 1);
    setCart(newCart);
  };

  const handleFileUpload = async (e: React.ChangeEvent<HTMLInputElement>) => {
    const file = e.target.files?.[0];
    if (!file) return;

    setIsUploading(true);
    const formData = new FormData();
    formData.append('image', file);

    try {
      const res = await fetch('/api/upload', {
        method: 'POST',
        headers: { 'x-admin-password': adminToken },
        body: formData,
      });
      const data = await res.json();
      if (data.imageUrl) {
        setAdminForm({ ...adminForm, image_url: data.imageUrl });
      }
    } catch (err) {
      console.error('Upload failed', err);
      alert('Failed to upload image');
    } finally {
      setIsUploading(false);
    }
  };

  const handleDeleteProduct = async (id: number) => {
    if (!confirm('هل أنت متأكد من حذف هذا المنتج؟')) return;
    try {
      const res = await fetch(`/api/products/${id}`, { 
        method: 'DELETE',
        headers: { 'x-admin-password': adminToken }
      });
      if (res.ok) {
        fetchProducts();
      }
    } catch (err) {
      console.error('Failed to delete product', err);
    }
  };

  const handleAdminLogin = (e: React.FormEvent) => {
    e.preventDefault();
    if (adminPasswordInput === '123456') {
      setIsAdminAuthenticated(true);
      setAdminToken(adminPasswordInput);
      setAdminPasswordInput('');
    } else {
      alert('كلمة المرور غير صحيحة!');
    }
  };

  const handleAdminSubmit = async (e: React.FormEvent) => {
    e.preventDefault();
    try {
      const url = editingId ? `/api/products/${editingId}` : '/api/products';
      const method = editingId ? 'PUT' : 'POST';
      
      const res = await fetch(url, {
        method,
        headers: { 
          'Content-Type': 'application/json',
          'x-admin-password': adminToken
        },
        body: JSON.stringify({ ...adminForm, price: parseFloat(adminForm.price) })
      });

      if (res.ok) {
        setAdminForm({ name: '', price: '', image_url: '', description: '', customizable: true });
        setEditingId(null);
        fetchProducts();
        alert(editingId ? 'تم تحديث المنتج بنجاح!' : 'تم إضافة المنتج بنجاح!');
      } else {
        const errorData = await res.json();
        alert(`فشل النشر: ${errorData.error || 'خطأ غير معروف'}`);
      }
    } catch (err) {
      console.error('Failed to save product', err);
      alert('حدث خطأ أثناء الاتصال بالخادم. يرجى المحاولة مرة أخرى.');
    }
  };

  const startEditing = (product: Product) => {
    setAdminForm({
      name: product.name,
      price: product.price.toString(),
      image_url: product.image_url,
      description: product.description || '',
      customizable: product.customizable === 1
    });
    setEditingId(product.id);
    window.scrollTo({ top: 0, behavior: 'smooth' });
  };

  const [isProcessingOrder, setIsProcessingOrder] = useState(false);

  const handleCheckout = async (e: React.FormEvent) => {
    e.preventDefault();
    if (cart.length === 0) return;
    
    setIsProcessingOrder(true);
    const subtotal = cart.reduce((sum, item) => sum + item.price, 0);
    const deliveryFee = DELIVERY_FEES[checkoutForm.location] || 0;
    const total_price = subtotal + deliveryFee;

    try {
      const res = await fetch('/api/orders', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          customer_name: checkoutForm.name,
          customer_email: checkoutForm.email,
          customer_phone: checkoutForm.phone,
          location: checkoutForm.location,
          total_price,
          items: cart.map(item => ({
            product_id: item.id,
            quantity: item.quantity,
            size: item.size,
            custom_image_url: item.custom_image_url
          }))
        })
      });

      if (res.ok) {
        const itemsList = cart.map(item => {
          let text = `- ${item.name} (${item.size}): ${item.price} ج.م`;
          if (item.custom_image_url) {
            text += `\n  [رابط التصميم: ${item.custom_image_url}]`;
          }
          return text;
        }).join('\n');

        const message = `*طلب جديد من متجر FABRIX*\n\n` +
          `*العميل:* ${checkoutForm.name}\n` +
          `*الهاتف:* ${checkoutForm.phone}\n` +
          `*الموقع:* ${checkoutForm.location}\n\n` +
          `*المنتجات:*\n${itemsList}\n\n` +
          `*المجموع الفرعي:* ${subtotal} ج.م\n` +
          `*مصاريف الشحن:* ${deliveryFee} ج.م\n` +
          `*الإجمالي النهائي:* ${total_price} ج.م\n\n` +
          `_تم إرسال الطلب عبر الموقع_`;
        
        const whatsappUrl = `https://wa.me/201155010785?text=${encodeURIComponent(message)}`;
        
        setLastWhatsappUrl(whatsappUrl);
        setCart([]);
        setOrderSuccess(true);
        setTimeout(() => setOrderSuccess(false), 8000);
        setView('home');
        
        const win = window.open(whatsappUrl, '_blank');
        if (!win) {
          window.location.href = whatsappUrl;
        }
      } else {
        const errorData = await res.json();
        alert(`فشل إتمام الطلب: ${errorData.error || 'خطأ غير معروف'}`);
      }
    } catch (err) {
      console.error('Failed to place order', err);
      alert('حدث خطأ أثناء إتمام الطلب. يرجى المحاولة مرة أخرى.');
    } finally {
      setIsProcessingOrder(false);
    }
  };

  const cartTotal = cart.reduce((sum, item) => sum + item.price, 0);

  return (
    <div className="min-h-screen bg-[#FDFCFB] text-[#1A1A1A] font-sans">
      <nav className="sticky top-0 z-50 bg-white/80 backdrop-blur-md border-b border-black/5 px-6 py-4 flex justify-between items-center">
        <div className="flex items-center gap-2 cursor-pointer" onClick={() => setView('home')}>
          <div className="w-10 h-10 bg-black rounded-xl flex items-center justify-center text-white font-bold text-xl">F</div>
          <span className="text-2xl font-bold tracking-tighter">FABRIX</span>
        </div>
        
        <div className="flex items-center gap-6">
          <button onClick={() => setView('home')} className={`text-sm font-medium transition-colors ${view === 'home' ? 'text-black' : 'text-black/40 hover:text-black'}`}>Shop</button>
          <button onClick={() => setView('admin')} className={`text-sm font-medium transition-colors ${view === 'admin' ? 'text-black' : 'text-black/40 hover:text-black'}`}>Admin</button>
          <button onClick={handleShareStore} className="p-2 hover:bg-black/5 rounded-full transition-colors text-black/60 hover:text-black" title="مشاركة المتجر"><Share2 size={22} /></button>
          <button onClick={() => setView('cart')} className="relative p-2 hover:bg-black/5 rounded-full transition-colors">
            <ShoppingCart size={22} />
            {cart.length > 0 && <span className="absolute -top-1 -right-1 bg-black text-white text-[10px] font-bold w-5 h-5 rounded-full flex items-center justify-center border-2 border-white">{cart.length}</span>}
          </button>
        </div>
      </nav>

      <main className="max-w-7xl mx-auto px-6 py-12">
        <AnimatePresence mode="wait">
          {view === 'home' && (
            <motion.div key="home" initial={{ opacity: 0, y: 20 }} animate={{ opacity: 1, y: 0 }} exit={{ opacity: 0, y: -20 }}>
              <div className="mb-12">
                <h1 className="text-5xl font-bold tracking-tight mb-4">Premium Hoodies</h1>
                <p className="text-black/60 text-lg max-w-2xl">Choose from our curated collection of high-quality hoodies or upload your own design for a truly unique look.</p>
              </div>

              {orderSuccess && (
                <div className="mb-8 p-6 bg-emerald-50 border border-emerald-100 text-emerald-700 rounded-[32px] flex flex-col md:flex-row items-center justify-between gap-4 shadow-sm">
                  <div className="flex items-center gap-3">
                    <div className="w-10 h-10 bg-emerald-500 text-white rounded-full flex items-center justify-center"><Check size={20} /></div>
                    <div>
                      <p className="font-bold text-lg">تم إرسال طلبك بنجاح!</p>
                      <p className="text-sm opacity-80">سنقوم بالتواصل معك قريباً لتأكيد الطلب.</p>
                    </div>
                  </div>
                  {lastWhatsappUrl && <a href={lastWhatsappUrl} target="_blank" rel="noopener noreferrer" className="bg-emerald-500 text-white px-6 py-3 rounded-full font-bold text-sm flex items-center gap-2 hover:bg-emerald-600 transition-all shadow-md">إرسال عبر واتساب يدوياً</a>}
                </div>
              )}

              <div className="space-y-16">
                {Object.entries(products.reduce((acc: { [key: number]: Product[] }, product) => {
                  const price = product.price;
                  if (!acc[price]) acc[price] = [];
                  acc[price].push(product);
                  return acc;
                }, {})).sort(([priceA], [priceB]) => Number(priceA) - Number(priceB)).map(([price, priceGroup]) => (
                  <div key={price}>
                    <div className="flex items-center gap-4 mb-8">
                      <h2 className="text-2xl font-bold text-black/80">{price} ج.م</h2>
                      <div className="h-px bg-black/5 flex-1"></div>
                    </div>
                    <div className="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-8">
                      {(priceGroup as Product[]).map((product) => (
                        <motion.div key={product.id} whileHover={{ y: -8 }} className="group cursor-pointer" onClick={() => { setSelectedProduct(product); setView('product'); }}>
                          <div className="aspect-[3/4] rounded-3xl overflow-hidden bg-black/5 mb-4 relative">
                            <img src={product.image_url} alt={product.name} className="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110" referrerPolicy="no-referrer" />
                            {product.customizable === 1 && <div className="absolute top-4 left-4 bg-white/90 backdrop-blur-sm px-3 py-1 rounded-full text-[10px] font-bold uppercase tracking-wider shadow-sm">Customizable</div>}
                            <div className="absolute inset-0 bg-black/20 opacity-0 group-hover:opacity-100 transition-opacity flex items-center justify-center">
                              <span className="bg-white text-black px-6 py-3 rounded-full font-bold text-sm shadow-xl transform translate-y-4 group-hover:translate-y-0 transition-transform">View Details</span>
                            </div>
                          </div>
                          <div className="flex justify-between items-start">
                            <div><h3 className="font-bold text-xl mb-1">{product.name}</h3><p className="text-black/40 text-sm">{product.description}</p></div>
                            <span className="font-bold text-lg">{product.price} ج.م</span>
                          </div>
                        </motion.div>
                      ))}
                    </div>
                  </div>
                ))}
              </div>
            </motion.div>
          )}

          {view === 'product' && selectedProduct && (
            <motion.div key="product" initial={{ opacity: 0, scale: 0.95 }} animate={{ opacity: 1, scale: 1 }} exit={{ opacity: 0, scale: 0.95 }} className="grid grid-cols-1 lg:grid-cols-2 gap-12 items-start">
              <div className="aspect-[3/4] rounded-[40px] overflow-hidden bg-black/5 shadow-2xl">
                <img src={selectedProduct.image_url} alt={selectedProduct.name} className="w-full h-full object-cover" referrerPolicy="no-referrer" />
              </div>
              <div className="py-8">
                <button onClick={() => setView('home')} className="text-black/40 hover:text-black mb-8 flex items-center gap-1 text-sm font-medium"><X size={16} /> Back to shop</button>
                <h1 className="text-5xl font-bold tracking-tight mb-4">{selectedProduct.name}</h1>
                <div className="flex items-center gap-4 mb-8">
                  <p className="text-3xl font-bold">{selectedProduct.price} ج.م</p>
                  {selectedProduct.customizable === 1 && <span className="bg-emerald-50 text-emerald-700 px-3 py-1 rounded-full text-[10px] font-bold uppercase tracking-wider border border-emerald-100">Custom Design Available</span>}
                </div>
                <div className="mb-8">
                  <p className="text-sm font-bold uppercase tracking-widest text-black/40 mb-4">Select Size</p>
                  <div className="flex gap-3">
                    {['S', 'M', 'L', 'XL'].map(size => (
                      <button key={size} onClick={() => setSelectedSize(size)} className={`w-14 h-14 rounded-2xl border-2 flex items-center justify-center font-bold transition-all ${selectedSize === size ? 'border-black bg-black text-white' : 'border-black/5 hover:border-black/20'}`}>{size}</button>
                    ))}
                  </div>
                </div>
                {selectedProduct.customizable === 1 && (
                  <div className="mb-12 p-8 bg-black/5 rounded-[32px] border border-black/5">
                    <div className="flex items-center gap-3 mb-4"><Upload size={20} className="text-black/40" /><p className="text-sm font-bold uppercase tracking-widest text-black/40">Custom Design (Optional)</p></div>
                    <p className="text-sm text-black/60 mb-6">Want to add your own design? Paste an image URL below to see it on your hoodie.</p>
                    <input type="text" placeholder="https://example.com/my-design.png" value={customImageUrl} onChange={(e) => setCustomImageUrl(e.target.value)} className="w-full px-6 py-4 rounded-2xl bg-white border border-black/5 focus:outline-none focus:ring-2 focus:ring-black/5 transition-all" />
                    {customImageUrl && <div className="mt-6 p-4 bg-white rounded-2xl border border-black/5 flex items-center gap-4"><img src={customImageUrl} alt="Preview" className="w-16 h-16 object-cover rounded-lg" referrerPolicy="no-referrer" /><div><p className="text-xs font-bold text-black/40 uppercase">Design Preview</p><p className="text-sm font-medium">Custom print ready</p></div></div>}
                  </div>
                )}
                <button onClick={() => addToCart(selectedProduct)} disabled={isAddingToCart} className={`w-full py-6 rounded-[32px] font-bold text-lg shadow-2xl transition-all flex items-center justify-center gap-3 ${isAddingToCart ? 'bg-emerald-500 text-white' : 'bg-black text-white hover:scale-[1.02] active:scale-[0.98]'}`}>
                  {isAddingToCart ? <><Check size={24} /> Added to Cart</> : <><Plus size={24} /> Add to Cart — {selectedProduct.price} ج.م</>}
                </button>
              </div>
            </motion.div>
          )}

          {view === 'cart' && (
            <motion.div key="cart" initial={{ opacity: 0, x: 20 }} animate={{ opacity: 1, x: 0 }} exit={{ opacity: 0, x: -20 }} className="grid grid-cols-1 lg:grid-cols-3 gap-12">
              <div className="lg:col-span-2">
                <h1 className="text-4xl font-bold tracking-tight mb-8">Your Cart</h1>
                {cart.length === 0 ? (
                  <div className="py-20 text-center bg-black/5 rounded-[40px]"><ShoppingCart size={48} className="mx-auto mb-4 text-black/20" /><p className="text-black/40 font-medium mb-6">Your cart is empty</p><button onClick={() => setView('home')} className="bg-black text-white px-8 py-4 rounded-full font-bold">Start Shopping</button></div>
                ) : (
                  <div className="space-y-6">
                    {cart.map((item, index) => (
                      <div key={index} className="flex gap-6 p-6 bg-white rounded-[32px] border border-black/5 shadow-sm">
                        <img src={item.image_url} alt={item.name} className="w-32 h-32 object-cover rounded-2xl" referrerPolicy="no-referrer" />
                        <div className="flex-1">
                          <div className="flex justify-between items-start mb-2"><h3 className="font-bold text-xl">{item.name}</h3><button onClick={() => removeFromCart(index)} className="text-black/20 hover:text-red-500 transition-colors"><Trash2 size={20} /></button></div>
                          <div className="flex gap-4 text-sm font-medium text-black/40 mb-4"><span>Size: {item.size}</span>{item.custom_image_url && <span className="text-emerald-600">Custom Design Included</span>}</div>
                          <p className="font-bold text-lg">{item.price} ج.م</p>
                        </div>
                      </div>
                    ))}
                  </div>
                )}
              </div>
              <div className="lg:col-span-1">
                <div className="bg-white p-8 rounded-[40px] border border-black/5 shadow-xl sticky top-32">
                  <h2 className="text-2xl font-bold mb-8">Order Summary</h2>
                  <div className="space-y-4 mb-8">
                    <div className="flex justify-between text-black/60"><span>Subtotal</span><span>{cartTotal.toFixed(2)} ج.م</span></div>
                    <div className="space-y-2"><label className="text-xs font-bold uppercase tracking-widest text-black/40">Location</label><select value={checkoutForm.location} onChange={(e) => setCheckoutForm({ ...checkoutForm, location: e.target.value })} className="w-full px-4 py-3 rounded-xl bg-black/5 border border-transparent focus:bg-white focus:border-black/10 focus:outline-none transition-all text-sm">{Object.keys(DELIVERY_FEES).map(loc => (<option key={loc} value={loc}>{loc}</option>))}</select></div>
                    <div className="flex justify-between text-black/60"><span>Shipping ({checkoutForm.location})</span><span>{DELIVERY_FEES[checkoutForm.location]} ج.م</span></div>
                    <div className="pt-4 border-t border-black/5 flex justify-between text-xl font-bold"><span>Total</span><span>{(cartTotal + (DELIVERY_FEES[checkoutForm.location] || 0)).toFixed(2)} ج.م</span></div>
                  </div>
                  {cart.length > 0 && (
                    <form onSubmit={handleCheckout} className="space-y-4">
                      <input type="text" placeholder="الاسم بالكامل" required value={checkoutForm.name} onChange={(e) => setCheckoutForm({ ...checkoutForm, name: e.target.value })} className="w-full px-6 py-4 rounded-2xl bg-black/5 border border-transparent focus:bg-white focus:border-black/10 focus:outline-none transition-all" />
                      <input type="tel" placeholder="رقم الهاتف" required value={checkoutForm.phone} onChange={(e) => setCheckoutForm({ ...checkoutForm, phone: e.target.value })} className="w-full px-6 py-4 rounded-2xl bg-black/5 border border-transparent focus:bg-white focus:border-black/10 focus:outline-none transition-all" />
                      <input type="email" placeholder="البريد الإلكتروني" required value={checkoutForm.email} onChange={(e) => setCheckoutForm({ ...checkoutForm, email: e.target.value })} className="w-full px-6 py-4 rounded-2xl bg-black/5 border border-transparent focus:bg-white focus:border-black/10 focus:outline-none transition-all" />
                      <button type="submit" disabled={isProcessingOrder} className={`w-full py-6 bg-black text-white rounded-[32px] font-bold text-lg shadow-2xl hover:scale-[1.02] active:scale-[0.98] transition-all ${isProcessingOrder ? 'opacity-50 cursor-not-allowed' : ''}`}>{isProcessingOrder ? 'جاري المعالجة...' : 'إتمام الطلب'}</button>
                    </form>
                  )}
                </div>
              </div>
            </motion.div>
          )}

          {view === 'admin' && (
            <motion.div key="admin" initial={{ opacity: 0, y: 20 }} animate={{ opacity: 1, y: 0 }} exit={{ opacity: 0, y: -20 }} className="max-w-2xl mx-auto">
              {!isAdminAuthenticated ? (
                <div className="bg-white p-10 rounded-[48px] border border-black/5 shadow-2xl text-center">
                  <div className="w-20 h-20 bg-black/5 rounded-[32px] flex items-center justify-center mx-auto mb-6"><User size={32} className="text-black/40" /></div>
                  <h1 className="text-3xl font-bold mb-4">دخول الإدارة</h1>
                  <form onSubmit={handleAdminLogin} className="space-y-4">
                    <input type="password" placeholder="كلمة المرور" required value={adminPasswordInput} onChange={(e) => setAdminPasswordInput(e.target.value)} className="w-full px-8 py-5 rounded-3xl bg-black/5 border border-transparent focus:bg-white focus:border-black/10 focus:outline-none transition-all text-center" />
                    <button type="submit" className="w-full py-6 bg-black text-white rounded-[32px] font-bold text-lg shadow-2xl hover:scale-[1.02] active:scale-[0.98] transition-all">دخول</button>
                  </form>
                </div>
              ) : (
                <>
                  <div className="flex justify-between items-center mb-12">
                    <div className="text-left"><h1 className="text-4xl font-bold tracking-tight mb-2">لوحة التحكم</h1><p className="text-black/40">إدارة منتجات المتجر والمخزون.</p></div>
                    <button onClick={() => setIsAdminAuthenticated(false)} className="px-6 py-3 bg-black/5 text-black/60 rounded-full text-sm font-bold hover:bg-black/10 transition-all">تسجيل خروج</button>
                  </div>
                  <div className="bg-white p-10 rounded-[48px] border border-black/5 shadow-2xl">
                    <h2 className="text-2xl font-bold mb-8 flex items-center gap-3">{editingId ? <Edit2 size={24} /> : <Plus size={24} />} {editingId ? 'تعديل المنتج' : 'إضافة منتج جديد'}</h2>
                    <form onSubmit={handleAdminSubmit} className="space-y-6">
                      <div className="space-y-2"><label className="text-xs font-bold uppercase tracking-widest text-black/40 ml-2">اسم المنتج</label><input type="text" placeholder="مثال: هودي قطن أسود" required value={adminForm.name} onChange={(e) => setAdminForm({ ...adminForm, name: e.target.value })} className="w-full px-8 py-5 rounded-3xl bg-black/5 border border-transparent focus:bg-white focus:border-black/10 focus:outline-none transition-all" /></div>
                      <div className="grid grid-cols-2 gap-6">
                        <div className="space-y-2"><label className="text-xs font-bold uppercase tracking-widest text-black/40 ml-2">السعر (ج.م)</label><input type="number" step="0.01" placeholder="450.00" required value={adminForm.price} onChange={(e) => setAdminForm({ ...adminForm, price: e.target.value })} className="w-full px-8 py-5 rounded-3xl bg-black/5 border border-transparent focus:bg-white focus:border-black/10 focus:outline-none transition-all" /></div>
                        <div className="space-y-2"><label className="text-xs font-bold uppercase tracking-widest text-black/40 ml-2">الصورة</label><div className="flex flex-col gap-4"><input type="text" placeholder="رابط الصورة" required value={adminForm.image_url} onChange={(e) => setAdminForm({ ...adminForm, image_url: e.target.value })} className="w-full px-8 py-5 rounded-3xl bg-black/5 border border-transparent focus:bg-white focus:border-black/10 focus:outline-none transition-all" /></div></div>
                      </div>
                      <div className="space-y-2"><label className="text-xs font-bold uppercase tracking-widest text-black/40 ml-2">الوصف</label><textarea placeholder="تفاصيل المنتج..." rows={4} value={adminForm.description} onChange={(e) => setAdminForm({ ...adminForm, description: e.target.value })} className="w-full px-8 py-5 rounded-3xl bg-black/5 border border-transparent focus:bg-white focus:border-black/10 focus:outline-none transition-all resize-none" /></div>
                      <div className="flex items-center gap-3 ml-2"><input type="checkbox" id="customizable" checked={adminForm.customizable} onChange={(e) => setAdminForm({ ...adminForm, customizable: e.target.checked })} className="w-5 h-5 rounded border-black/10 text-black focus:ring-black" /><label htmlFor="customizable" className="text-sm font-medium">السماح برفع تصميم خاص</label></div>
                      <button type="submit" className="w-full py-6 bg-black text-white rounded-[32px] font-bold text-lg shadow-2xl hover:scale-[1.02] active:scale-[0.98] transition-all mt-4">{editingId ? 'تحديث المنتج' : 'نشر المنتج'}</button>
                    </form>
                  </div>
                  <div className="mt-12 bg-white p-10 rounded-[48px] border border-black/5 shadow-2xl">
                    <h2 className="text-2xl font-bold mb-8 flex items-center gap-3"><Package size={24} /> إدارة المنتجات</h2>
                    <div className="space-y-4">
                      {products.map((product) => (
                        <div key={product.id} className="flex items-center justify-between p-4 bg-black/5 rounded-2xl">
                          <div className="flex items-center gap-4"><img src={product.image_url} alt={product.name} className="w-12 h-12 object-cover rounded-lg" referrerPolicy="no-referrer" /><div><p className="font-bold text-sm">{product.name}</p><p className="text-xs text-black/40">{product.price} ج.م</p></div></div>
                          <div className="flex items-center gap-2">
                            <button onClick={() => startEditing(product)} className="p-2 text-black/20 hover:text-blue-500 transition-colors"><Edit2 size={20} /></button>
                            <button onClick={() => handleDeleteProduct(product.id)} className="p-2 text-black/20 hover:text-red-500 transition-colors"><Trash2 size={20} /></button>
                          </div>
                        </div>
                      ))}
                    </div>
                  </div>
                </>
              )}
            </motion.div>
          )}
        </AnimatePresence>
      </main>

      <footer className="border-t border-black/5 py-20 px-6 mt-20">
        <div className="max-w-7xl mx-auto grid grid-cols-1 md:grid-cols-4 gap-12">
          <div className="col-span-2">
            <div className="flex items-center gap-2 mb-6"><div className="w-8 h-8 bg-black rounded-lg flex items-center justify-center text-white font-bold">F</div><span className="text-xl font-bold tracking-tighter">FABRIX</span></div>
            <p className="text-black/40 max-w-sm leading-relaxed">Premium quality hoodies designed for comfort and style. Customize your look with our easy-to-use design tools.</p>
          </div>
          <div><h4 className="font-bold mb-6 uppercase text-xs tracking-widest text-black/40">Shop</h4><ul className="space-y-4 text-sm font-medium"><li>New Arrivals</li><li>Custom Design</li></ul></div>
        </div>
        <div className="max-w-7xl mx-auto pt-20 flex justify-between items-center text-xs font-bold uppercase tracking-widest text-black/20"><span>© 2024 FABRIX CO.</span><span>MADE WITH LOVE</span></div>
      </footer>
    </div>
  );
}
